# API URL (backend). Leave empty in dev to use Vite’s proxy (see vite.config.ts) — requests go to same origin :8080 and forward to :3001.
# Or set explicitly: http://localhost:3001
VITE_API_URL=

# TonConnect manifest URL. Use a path like below so the dev server serves it (same origin as the app).
# Do NOT point this at the API port (e.g. http://localhost:3001/...) — that returns 404 for the manifest.
# For mobile / Telegram, use a public HTTPS URL to the manifest.
# Example: https://your-app-domain.com/tonconnect-manifest.json
VITE_TONCONNECT_MANIFEST_URL=/tonconnect-manifest.json

# TWA Return URL (for Telegram Mini Apps)
VITE_TWA_RETURN_URL=

# Backend can allow localhost wallet auth without ton_proof in dev only.
# Set on backend env, not frontend:
# ALLOW_LOCAL_WALLET_AUTH_BYPASS=true
